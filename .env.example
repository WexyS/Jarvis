# AirLLM (Llama 3.1 405B - 4-bit compression)
# 405B model → ~230GB disk, ~8GB VRAM
AIRLLM_MODEL=meta-llama/Llama-3.1-405B-Instruct
AIRLLM_COMPRESSION=4bit
AIRLLM_PREFETCHING=true

# MiniMax M2.7 (Self-evolving model - 10B params)
# Available via OpenRouter or official API
MINIMAX_API_KEY=your_api_key_here  # Or use OPENROUTER_API_KEY
MINIMAX_BASE_URL=https://openrouter.ai/api/v1  # Or https://api.minimaxi.com/v1
MINIMAX_DEFAULT_MODEL=minimax/minimax-m2.7
