# Jarvis Ortam Değişkenleri
# Tamamen yerel çalışır — API anahtarı gerektirmez

# E-posta kimlik bilgileri (sabah özeti için)
JARVIS_EMAIL_USER=your_email@gmail.com
JARVIS_EMAIL_PASS=

# Ollama sunucu adresi (varsayılan: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════════
# Çoklu Sağlayıcı Desteği (Opsiyonel — hepsi ücretsiz)
# ═══════════════════════════════════════════════════════════

# OpenRouter (ücretsiz + ücretli modeller — tek API key)
# openrouter.ai → Settings → API Keys
OPENROUTER_API_KEY=OPENROUTER_API_KEY_PLACEHOLDER

# Groq (süper hızlı, ücretsiz — 300-500 tok/s)
# console.groq.com → API Keys
GROQ_API_KEY=GROQ_API_KEY_PLACEHOLDERxSfxnUtFhLdUQuWGdyb3FYqpx1jUN70yBx9XTP99k9fxKq

# Google Gemini (ücretsiz, 1M context, 60 req/dk)
# aistudio.google.com → API Key
GEMINI_API_KEY=GEMINI_API_KEY_PLACEHOLDER

# Cloudflare Workers AI (ücretsiz, 10K/gün)
# dash.cloudflare.com → API Tokens + Account ID
CLOUDFLARE_API_KEY=CLOUDFLARE_API_KEY_PLACEHOLDER
CLOUDFLARE_ACCOUNT_ID=CLOUDFLARE_ACCOUNT_ID_PLACEHOLDER

# Together AI ($25 ücretsiz kredi)
# api.together.xyz → Settings → API Keys
TOGETHER_API_KEY=TOGETHER_API_KEY_PLACEHOLDER

# Hugging Face Inference API (ücretsiz)
# huggingface.co → Settings → Access Tokens
HF_API_KEY=hf_...

# OpenAI (ücretli — son çare fallback)
OPENAI_API_KEY=OPENAI_API_KEY_PLACEHOLDER
OPENAI_MODEL=gpt-4o
